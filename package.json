{
  "name": "iso-online-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --config prisma/prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --name init --config prisma/prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma/prisma.config.ts",
    "prisma:db-push": "prisma db push --config prisma/prisma.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tantonPeerapat/iso-online-backend.git"
  },
